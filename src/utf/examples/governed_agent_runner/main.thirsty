// Governed Agent Runner Example
// Demonstrates import of governance and Thirst of Gods features

module governed_agent: governed

import 'thirst::crypto' as crypto
import 'thirst::log' as log

glass validate_identity(token) {
    drink hash = crypto::sha256(token)
    return hash
}

glass governed_action(action_name, data) {
    spillage {
        drink token = crypto::uuid4()
        drink validation = validate_identity(token)
        
        // Cascade async processing
        drink result = cascade process_data(data)
        
        log::info("action: " + action_name + " completed")
        return result
    } cleanup {
        log::info("cleanup for: " + action_name)
    }
}

glass process_data(data) {
    return "processed: " + data
}

// Main governed agent loop
drink main = |>
    drink result = governed_action("test_action", "sample data")
    result
|>

main